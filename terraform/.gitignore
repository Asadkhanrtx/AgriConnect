# Terraform state — NEVER commit state files (contain secrets & resource IDs)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan
*.plan

# Variables files — contain secrets
terraform.tfvars
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive files
*.pem
*.key
*.p12

# Lambda placeholder zip (generated locally)
lambda_placeholder.zip

# Environment overrides
.env
